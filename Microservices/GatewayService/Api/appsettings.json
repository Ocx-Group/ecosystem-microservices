{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE",
    "Issuer": "Ecosystem",
    "Audience": "Ecosystem"
  },

  "Cors": {
    "AllowedOrigins": [ "*" ]
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 10,
    "QueueLimit": 10
  },

  "DownstreamServices": {
    "AccountService": {
      "BaseUrl": "http://account-service:8080",
      "HealthUrl": "http://account-service:8080/health",
      "SwaggerUrl": "http://account-service:8080/swagger/v1/swagger.json"
    },
    "ConfigurationService": {
      "BaseUrl": "http://configuration-service:8080",
      "HealthUrl": "http://configuration-service:8080/health",
      "SwaggerUrl": "http://configuration-service:8080/swagger/v1/swagger.json"
    },
    "InventoryService": {
      "BaseUrl": "http://inventory-service:8080",
      "HealthUrl": "http://inventory-service:8080/health",
      "SwaggerUrl": "http://inventory-service:8080/swagger/v1/swagger.json"
    },
    "WalletService": {
      "BaseUrl": "http://wallet-service:8080",
      "HealthUrl": "http://wallet-service:8080/health",
      "SwaggerUrl": "http://wallet-service:8080/swagger/v1/swagger.json"
    },
    "NotificationService": {
      "BaseUrl": "http://notification-service:8080",
      "HealthUrl": "http://notification-service:8080/health",
      "SwaggerUrl": "http://notification-service:8080/swagger/v1/swagger.json"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "account-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "global",
        "Match": {
          "Path": "/api/{version}/account/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{version}/account/{**catch-all}" }
        ]
      },
      "account-users-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "anonymous",
